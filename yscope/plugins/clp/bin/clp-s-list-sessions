#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  clp-s-list-sessions [options]

List Claude Code session JSONL files under ~/.claude/projects and
write a stable selection manifest for later compression.

Options:
  --source-root DIR       Directory to scan.
                          Default: ~/.claude/projects
  --limit N               Number of recent sessions to show. Default: 5
  --all                   Include every matching session in the manifest/table.
  --include-subagents     Include subagent JSONL files.
  --manifest PATH         Write selection manifest to PATH.
  --project-filter TEXT   Only include paths/cwd/project labels containing TEXT.
  -h, --help              Show this help.

Output:
  The table's IDX column is stable for the printed Selection manifest. Compress
  one selected row with:

    clp-s-compress-claude-projects --selection-file <manifest> --session-index <IDX>
EOF
}

source_root="${CLP_S_CLAUDE_PROJECTS_ROOT:-${HOME:-}/.claude/projects}"
limit=5
include_all=0
include_subagents=0
manifest=""
project_filter=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source-root)
      [[ $# -ge 2 ]] || { echo "error: --source-root requires a value" >&2; exit 2; }
      source_root="$2"
      shift 2
      ;;
    --limit)
      [[ $# -ge 2 ]] || { echo "error: --limit requires a value" >&2; exit 2; }
      limit="$2"
      shift 2
      ;;
    --all)
      include_all=1
      shift
      ;;
    --include-subagents)
      include_subagents=1
      shift
      ;;
    --manifest)
      [[ $# -ge 2 ]] || { echo "error: --manifest requires a value" >&2; exit 2; }
      manifest="$2"
      shift 2
      ;;
    --project-filter)
      [[ $# -ge 2 ]] || { echo "error: --project-filter requires a value" >&2; exit 2; }
      project_filter="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      echo "error: arbitrary passthrough is not exposed by this wrapper" >&2
      exit 2
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      echo >&2
      usage >&2
      exit 2
      ;;
  esac
done

if ! [[ "$limit" =~ ^[0-9]+$ ]] || [[ "$limit" -eq 0 ]]; then
  echo "error: --limit must be a positive integer" >&2
  exit 2
fi

if [[ ! -d "$source_root" ]]; then
  echo "error: source root does not exist or is not a directory: $source_root" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "error: jq is required to summarize Claude session metadata" >&2
  exit 127
fi

if [[ -z "$manifest" ]]; then
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  manifest="${TMPDIR:-/tmp}/clp-s-session-selection-${stamp}.$$.tsv"
fi

tmp_candidates="$(mktemp "${TMPDIR:-/tmp}/clp-s-session-candidates.XXXXXX")"
trap 'rm -f "$tmp_candidates"' EXIT

find_args=("$source_root" -type f -name '*.jsonl')
if [[ "$include_subagents" -eq 0 ]]; then
  find_args+=(! -path '*/subagents/*')
fi

find "${find_args[@]}" -printf '%T@\t%s\t%p\n' | LC_ALL=C sort -t $'\t' -k1,1nr > "$tmp_candidates"

mkdir -p "$(dirname "$manifest")"
printf 'index\tmodified_epoch\tmodified_local\tsize_bytes\tkind\tsession_id\tproject\tcwd\tpath\n' > "$manifest"

format_bytes() {
  local bytes="$1"
  if (( bytes >= 1073741824 )); then
    awk -v b="$bytes" 'BEGIN { printf "%.1fG", b / 1073741824 }'
  elif (( bytes >= 1048576 )); then
    awk -v b="$bytes" 'BEGIN { printf "%.1fM", b / 1048576 }'
  elif (( bytes >= 1024 )); then
    awk -v b="$bytes" 'BEGIN { printf "%.1fK", b / 1024 }'
  else
    printf '%sB' "$bytes"
  fi
}

first_json_field() {
  local file="$1"
  local field="$2"
  head -n 200 "$file" \
    | jq -r --arg field "$field" 'select(.[$field]? != null and .[$field] != "") | .[$field]' 2>/dev/null \
    | head -n 1 || true
}

printed=0
matched_total=0
printf 'Selection manifest: %s\n' "$manifest"
printf 'Source root: %s\n' "$source_root"
if [[ "$include_subagents" -eq 0 ]]; then
  printf 'Subagents: excluded (use --include-subagents to include)\n'
else
  printf 'Subagents: included\n'
fi
printf '\n'
printf '%-4s  %-19s  %-8s  %-8s  %-36s  %-42s  %s\n' \
  "IDX" "MODIFIED" "SIZE" "KIND" "SESSION" "PROJECT/CWD" "PATH"

while IFS=$'\t' read -r mtime size path; do
  rel="${path#"$source_root"/}"
  project="${rel%%/*}"
  kind="main"
  if [[ "$path" == */subagents/* ]]; then
    kind="subagent"
  fi

  session_id="$(basename "$path" .jsonl)"
  cwd=""
  if [[ -n "$project_filter" ]]; then
    cwd="$(first_json_field "$path" cwd)"
    if [[ -z "$cwd" ]]; then
      cwd="$project"
    fi

    haystack="${project} ${cwd} ${path}"
    if [[ "$haystack" != *"$project_filter"* ]]; then
      continue
    fi
  fi

  matched_total=$((matched_total + 1))
  if [[ "$include_all" -eq 0 && "$printed" -ge "$limit" ]]; then
    continue
  fi

  if [[ -z "${cwd:-}" ]]; then
    cwd="$(first_json_field "$path" cwd)"
    if [[ -z "$cwd" ]]; then
      cwd="$project"
    fi
  fi

  printed=$((printed + 1))
  epoch="${mtime%%.*}"
  modified_local="$(date -d "@$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || printf '%s' "$epoch")"
  size_human="$(format_bytes "$size")"
  display_cwd="$cwd"
  if [[ ${#display_cwd} -gt 42 ]]; then
    display_cwd="...${display_cwd: -39}"
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$printed" "$epoch" "$modified_local" "$size" "$kind" "$session_id" "$project" "$cwd" "$path" \
    >> "$manifest"

  printf '%-4s  %-19s  %-8s  %-8s  %-36s  %-42s  %s\n' \
    "$printed" "$modified_local" "$size_human" "$kind" "$session_id" "$display_cwd" "$path"
done < "$tmp_candidates"

printf '\n'
printf 'Matched sessions: %s\n' "$matched_total"
printf 'Listed sessions: %s\n' "$printed"
printf 'Selection manifest: %s\n' "$manifest"

if [[ "$matched_total" -gt "$printed" ]]; then
  printf 'More sessions are available. Re-run with --limit N, --all, or --project-filter TEXT.\n'
fi
