#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  clp-s-decompress [options] ARCHIVES_DIR OUTPUT_DIR

Decompress a regular clp-s archive directory into OUTPUT_DIR.

Allowed controls:
  --archive-id ID                    Limit decompression to one archive ID.
  --ordered                          Decompress records in log order.
  --target-ordered-chunk-size SIZE   Chunk ordered output files by size.
  --print-ordered-chunk-stats        Print ordered chunk statistics.
  --dry-run                          Print the planned decompression only.
  -h, --help                         Show this help.

This wrapper intentionally does not expose network/S3 auth, MongoDB metadata
output, or arbitrary clp-s option passthrough.
EOF
}

archive_id=""
ordered=0
target_ordered_chunk_size=""
print_ordered_chunk_stats=0
dry_run=0
archives_dir=""
output_dir=""

resolve_clp_s() {
  local script_dir plugin_root candidate

  if [[ -n "${CLP_S_BIN:-}" ]]; then
    if [[ -x "$CLP_S_BIN" ]]; then
      printf '%s\n' "$CLP_S_BIN"
      return 0
    fi
    echo "error: CLP_S_BIN is set but is not executable: $CLP_S_BIN" >&2
    return 1
  fi

  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
  plugin_root="$(cd -- "${script_dir}/.." && pwd -P)"

  candidate="${script_dir}/clp-s"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="${plugin_root}/.clp-core/bin/clp-s"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if command -v clp-s >/dev/null 2>&1; then
    command -v clp-s
    return 0
  fi

  echo "error: clp-s is not available. Run the plugin installer or set CLP_S_BIN." >&2
  return 127
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --archive-id)
      [[ $# -ge 2 ]] || { echo "error: --archive-id requires a value" >&2; exit 2; }
      archive_id="$2"
      shift 2
      ;;
    --ordered)
      ordered=1
      shift
      ;;
    --target-ordered-chunk-size)
      [[ $# -ge 2 ]] || { echo "error: --target-ordered-chunk-size requires a value" >&2; exit 2; }
      target_ordered_chunk_size="$2"
      shift 2
      ;;
    --print-ordered-chunk-stats)
      print_ordered_chunk_stats=1
      shift
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --auth|--mongodb-uri|--mongodb-collection)
      echo "error: unsupported decompression option: $1" >&2
      exit 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      echo "error: arbitrary clp-s option passthrough is not exposed by this wrapper" >&2
      exit 2
      ;;
    -*)
      echo "error: unsupported option: $1" >&2
      echo >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ -z "$archives_dir" ]]; then
        archives_dir="$1"
      elif [[ -z "$output_dir" ]]; then
        output_dir="$1"
      else
        echo "error: unexpected positional argument: $1" >&2
        exit 2
      fi
      shift
      ;;
  esac
done

if [[ -z "$archives_dir" || -z "$output_dir" ]]; then
  usage >&2
  exit 2
fi

if [[ ! -d "$archives_dir" ]]; then
  echo "error: archives directory does not exist: $archives_dir" >&2
  exit 1
fi

output_parent="$(dirname -- "$output_dir")"
if [[ ! -d "$output_parent" ]]; then
  echo "error: output parent directory does not exist: $output_parent" >&2
  exit 1
fi

case "$(realpath -m "$output_dir")" in
  /|/home|/home/*/.claude|/home/*/.claude/projects)
    echo "error: refusing broad output directory: $output_dir" >&2
    exit 2
    ;;
esac

if [[ -n "$target_ordered_chunk_size" && "$ordered" -ne 1 ]]; then
  echo "error: --target-ordered-chunk-size requires --ordered" >&2
  exit 2
fi
if [[ "$print_ordered_chunk_stats" -eq 1 && "$ordered" -ne 1 ]]; then
  echo "error: --print-ordered-chunk-stats requires --ordered" >&2
  exit 2
fi

clp_s_bin="$(resolve_clp_s)" || exit $?

cmd=("$clp_s_bin" x)
if [[ "$ordered" -eq 1 ]]; then
  cmd+=(--ordered)
fi
if [[ -n "$target_ordered_chunk_size" ]]; then
  cmd+=(--target-ordered-chunk-size "$target_ordered_chunk_size")
fi
if [[ "$print_ordered_chunk_stats" -eq 1 ]]; then
  cmd+=(--print-ordered-chunk-stats)
fi
if [[ -n "$archive_id" ]]; then
  cmd+=(--archive-id "$archive_id")
fi
cmd+=("$archives_dir" "$output_dir")

echo "Archives dir: $archives_dir"
echo "Output dir: $output_dir"
printf 'Command:'
printf ' %q' "${cmd[@]}"
echo

if [[ "$dry_run" -eq 1 ]]; then
  exit 0
fi

exec "${cmd[@]}"
