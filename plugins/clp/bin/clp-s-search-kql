#!/usr/bin/env bash
set -euo pipefail

CLP_PLUGIN_BIN_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck disable=SC1091
source "${CLP_PLUGIN_BIN_DIR}/lib/clp-common.sh"

usage() {
  cat <<'EOF'
Usage:
  clp-s-search-kql [options] ARCHIVES_DIR KQL_QUERY

Run a restricted clp-s KQL search and return results on stdout.

Allowed search controls:
  --tge TS                 Find records with UNIX epoch timestamp >= TS ms.
  --tle TS                 Find records with UNIX epoch timestamp <= TS ms.
  -i, --ignore-case        Ignore case distinctions.
  --archive-id ID          Limit search to one archive ID.
  --project COLUMN         Project one column. May be repeated.
  --projection COLUMNS     Project comma-separated columns, e.g. level,message.
  --semantic-endpoint URL  Embedding service URL for semantic search.
  --semantic-top-k K       Return up to K nearest logtypes (default 5).
  --semantic-threshold T   Minimum similarity floor 0.0-1.0 (default 0.3).
  --embedding-batch-size N  Batch size for vector processing (default auto).

Examples:
  clp-s-search-kql /tmp/archive 'level:error'
  clp-s-search-kql /tmp/archive 'message.content.name:Bash'
  clp-s-search-kql /tmp/archive 'semantic("slow database queries")'
  clp-s-search-kql --project timestamp --project type --project sessionId /tmp/archive 'message.content.name:Bash'

This search wrapper intentionally does not expose clp-s output handlers,
reducers, results-cache writes, decompression, or arbitrary clp-s option
passthrough.

Semantic search uses semantic("query") in KQL and requires a running embedding
service. The wrapper health-checks the endpoint before search. Default
endpoint: https://embedding.yscope.ai/v1/similarity. Override with
--semantic-endpoint or CLP_SEMANTIC_ENDPOINT.
EOF
}

tge=""
tle=""
archive_id=""
ignore_case=0
projections=()
archives_dir=""
kql_query=""
semantic_endpoint=""
semantic_top_k=""
semantic_threshold=""
embedding_batch_size=""
semantic_active=0

split_projection_csv() {
  local value="$1"
  local item
  IFS=',' read -ra cols <<< "$value"
  for item in "${cols[@]}"; do
    item="${item#"${item%%[![:space:]]*}"}"
    item="${item%"${item##*[![:space:]]}"}"
    if [[ -n "$item" ]]; then
      projections+=("$item")
    fi
  done
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --semantic-endpoint)
      [[ $# -ge 2 ]] || { echo "error: --semantic-endpoint requires a value" >&2; exit 2; }
      semantic_endpoint="$2"
      semantic_active=1
      shift 2
      ;;
    --semantic-top-k)
      [[ $# -ge 2 ]] || { echo "error: --semantic-top-k requires a value" >&2; exit 2; }
      semantic_top_k="$2"
      semantic_active=1
      shift 2
      ;;
    --semantic-threshold)
      [[ $# -ge 2 ]] || { echo "error: --semantic-threshold requires a value" >&2; exit 2; }
      semantic_threshold="$2"
      semantic_active=1
      shift 2
      ;;
    --embedding-batch-size)
      [[ $# -ge 2 ]] || { echo "error: --embedding-batch-size requires a value" >&2; exit 2; }
      embedding_batch_size="$2"
      semantic_active=1
      shift 2
      ;;
    --tge)
      [[ $# -ge 2 ]] || { echo "error: --tge requires a value" >&2; exit 2; }
      tge="$2"
      shift 2
      ;;
    --tle)
      [[ $# -ge 2 ]] || { echo "error: --tle requires a value" >&2; exit 2; }
      tle="$2"
      shift 2
      ;;
    --archive-id)
      [[ $# -ge 2 ]] || { echo "error: --archive-id requires a value" >&2; exit 2; }
      archive_id="$2"
      shift 2
      ;;
    --project)
      [[ $# -ge 2 ]] || { echo "error: --project requires a value" >&2; exit 2; }
      projections+=("$2")
      shift 2
      ;;
    --projection)
      [[ $# -ge 2 ]] || { echo "error: --projection requires a value" >&2; exit 2; }
      split_projection_csv "$2"
      shift 2
      ;;
    -i|--ignore-case)
      ignore_case=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      echo "error: arbitrary clp-s option passthrough is not exposed by this wrapper" >&2
      exit 2
      ;;
    -*)
      echo "error: unsupported option: $1" >&2
      echo >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ -z "$archives_dir" ]]; then
        archives_dir="$1"
      elif [[ -z "$kql_query" ]]; then
        kql_query="$1"
      else
        echo "error: unexpected positional argument: $1" >&2
        exit 2
      fi
      shift
      ;;
  esac
done

if [[ -z "$archives_dir" || -z "$kql_query" ]]; then
  usage >&2
  exit 2
fi

if [[ "$kql_query" =~ [Ss][Ee][Mm][Aa][Nn][Tt][Ii][Cc][[:space:]]*\( ]]; then
  semantic_active=1
fi

clp_s_bin="$(resolve_clp_s)" || exit $?

if [[ ! -e "$archives_dir" ]]; then
  echo "error: archives path does not exist: $archives_dir" >&2
  exit 1
fi
print_archive_metadata_summary "$archives_dir"
input_archives_dir="$archives_dir"
archives_dir="$(resolve_clp_s_archive_dir "$archives_dir")" || {
  echo "error: could not find a clp-s archive directory under: $input_archives_dir" >&2
  echo "Pass either the top-level plugin archive directory or its inner clp-s archive directory." >&2
  exit 1
}
if [[ "$archives_dir" != "$input_archives_dir" ]]; then
  echo "Resolved clp-s archive dir: $archives_dir"
fi

if [[ "$semantic_active" -eq 1 ]]; then
  if [[ -z "$semantic_endpoint" ]]; then
    semantic_endpoint="${CLP_SEMANTIC_ENDPOINT:-${CLAUDE_PLUGIN_OPTION_SEMANTIC_ENDPOINT:-$DEFAULT_SEMANTIC_ENDPOINT}}"
  fi
  require_secure_url "$semantic_endpoint" || exit 2
  check_semantic_endpoint "$semantic_endpoint" || {
    echo "error: semantic endpoint is unavailable: $semantic_endpoint" >&2
    echo "  Check that the embedding service is running and reachable." >&2
    exit 1
  }
fi

search_options=()

if [[ -n "$tge" ]]; then
  search_options+=(--tge "$tge")
fi
if [[ -n "$tle" ]]; then
  search_options+=(--tle "$tle")
fi
if [[ "$ignore_case" -eq 1 ]]; then
  search_options+=(--ignore-case)
fi
if [[ -n "$archive_id" ]]; then
  search_options+=(--archive-id "$archive_id")
fi
if [[ "$semantic_active" -eq 1 ]]; then
  search_options+=(--semantic-endpoint "$semantic_endpoint")
fi
if [[ -n "$semantic_top_k" ]]; then
  search_options+=(--semantic-top-k "$semantic_top_k")
fi
if [[ -n "$semantic_threshold" ]]; then
  search_options+=(--semantic-threshold "$semantic_threshold")
fi
if [[ -n "$embedding_batch_size" ]]; then
  search_options+=(--embedding-batch-size "$embedding_batch_size")
fi

cmd=("$clp_s_bin" s ${search_options[@]+"${search_options[@]}"} "$archives_dir" "$kql_query")

if [[ ${#projections[@]} -gt 0 ]]; then
  cmd+=(--projection "${projections[@]}")
fi

printf 'Command:'
printf ' %q' "${cmd[@]}"
echo
if [[ "$semantic_active" -eq 1 ]]; then
  export CLP_SEMANTIC_ENDPOINT="$semantic_endpoint"
  if [[ -z "${CLP_SEMANTIC_BATCH_SIZE:-}" ]]; then
    unset CLP_SEMANTIC_BATCH_SIZE
  fi
  unset CLAUDE_PLUGIN_OPTION_SEMANTIC_ENDPOINT
else
  unset CLP_SEMANTIC_ENDPOINT CLP_SEMANTIC_BATCH_SIZE CLAUDE_PLUGIN_OPTION_SEMANTIC_ENDPOINT
fi
exec "${cmd[@]}"
